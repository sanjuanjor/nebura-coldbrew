---
import { withBase } from '../lib/i18n';

interface Props {
	title?: string;
	description?: string;
	lang?: 'es' | 'en';
}

const {
	title = 'Nebura Coffee | Cold Brew with Ultrasound',
	description = 'Nebura Coffee creates cold brew in minutes using ultrasound extraction technology.',
	lang = 'es',
} = Astro.props;

const faviconSvg = withBase('/favicon.svg');
const faviconIco = withBase('/favicon.ico');
const sharedBackground = withBase('/hero-coldbrew.png');
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={faviconSvg} />
		<link rel="icon" href={faviconIco} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body style={`--nebura-shared-bg: url('${sharedBackground}')`}>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	body {
		background-image: var(--nebura-shared-bg);
		background-size: cover;
		background-position: center;
		background-attachment: fixed;
	}
</style>
