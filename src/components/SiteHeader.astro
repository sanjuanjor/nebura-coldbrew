---
import { siteContent, type Locale } from '../content/site-content';
import { getLocalizedPath, withBase } from '../lib/i18n';

interface Props {
	current?: 'about' | 'technology' | 'people' | 'contact' | 'home';
	theme?: 'light' | 'dark';
	locale?: Locale;
}

const { current = 'home', theme = 'light', locale = 'es' } = Astro.props;
const linkClass = (key: Props['current']) => (current === key ? 'active' : '');
const copy = siteContent[locale];
---

<header class={`topbar ${theme}`}>
	<a href={withBase(getLocalizedPath(locale, 'home'))} class="brand" aria-label="Nebura Coffee">
		<span class="brand-text">NEBURA<br />COFFEE</span>
		<span class="brand-mark" aria-hidden="true"></span>
	</a>

	<nav aria-label="Main navigation" class="main-nav">
		<ul>
			<li><a class={linkClass('about')} href={withBase(getLocalizedPath(locale, 'about'))}>{copy.nav.about}</a></li>
			<li>
				<a class={linkClass('technology')} href={withBase(getLocalizedPath(locale, 'technology'))}
					>{copy.nav.technology}</a
				>
			</li>
			<li><a class={linkClass('people')} href={withBase(getLocalizedPath(locale, 'people'))}>{copy.nav.people}</a></li>
			<li><a class={linkClass('contact')} href={withBase(getLocalizedPath(locale, 'contact'))}>{copy.nav.contact}</a></li>
		</ul>
	</nav>

	<div class="lang-switch" aria-label="Language selector">
		<a href={withBase(getLocalizedPath('es', current))} class={locale === 'es' ? 'active' : ''}>ES</a>
		<a href={withBase(getLocalizedPath('en', current))} class={locale === 'en' ? 'active' : ''}>EN</a>
	</div>
</header>

<style>
	.topbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 20px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		padding: 12px 18px;
		background: rgba(255, 255, 255, 0.95);
		border-radius: 6px;
		text-decoration: none;
	}

	.brand-text {
		font-size: 15px;
		font-weight: 600;
		line-height: 1.1;
		letter-spacing: 0.08em;
		color: #2f2f2f;
	}

	.brand-mark {
		width: 24px;
		height: 24px;
		border-radius: 50%;
		background:
			radial-gradient(circle at 62% 38%, rgba(255, 255, 255, 0.75), rgba(0, 0, 0, 0) 50%),
			radial-gradient(circle at 35% 62%, #3c3c3c, #101010 70%);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.18);
	}

	.main-nav ul {
		list-style: none;
		display: flex;
		gap: 36px;
		margin: 0;
		padding: 0;
	}

	.main-nav a {
		text-decoration: none;
		font-size: 24px;
		font-family: 'Times New Roman', Georgia, serif;
		transition: opacity 0.2s ease;
	}

	.light .main-nav a {
		color: rgba(255, 255, 255, 0.88);
	}

	.dark .main-nav a {
		color: rgba(17, 17, 17, 0.86);
	}

	.main-nav a:hover,
	.main-nav a.active {
		opacity: 1;
		text-decoration: underline;
		text-underline-offset: 5px;
	}

	.lang-switch {
		display: inline-flex;
		border: 1px solid rgba(255, 255, 255, 0.38);
		border-radius: 999px;
		overflow: hidden;
	}

	.dark .lang-switch {
		border-color: rgba(17, 17, 17, 0.22);
	}

	.lang-switch a {
		padding: 6px 10px;
		font-size: 12px;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-decoration: none;
	}

	.light .lang-switch a {
		color: rgba(255, 255, 255, 0.85);
	}

	.dark .lang-switch a {
		color: rgba(17, 17, 17, 0.78);
	}

	.light .lang-switch a.active {
		background: rgba(255, 255, 255, 0.95);
		color: #171717;
	}

	.dark .lang-switch a.active {
		background: rgba(17, 17, 17, 0.9);
		color: #fff;
	}

	@media (max-width: 980px) {
		.topbar {
			align-items: flex-start;
			flex-direction: column;
		}

		.main-nav ul {
			gap: 16px;
			flex-wrap: wrap;
		}

		.main-nav a {
			font-size: 20px;
		}
	}
</style>
