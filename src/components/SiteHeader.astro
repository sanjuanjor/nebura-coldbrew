---
interface Props {
	current?: 'about' | 'technology' | 'people' | 'contact' | 'home';
	theme?: 'light' | 'dark';
}

const { current = 'home', theme = 'light' } = Astro.props;
const linkClass = (key: Props['current']) => (current === key ? 'active' : '');
---

<header class={`topbar ${theme}`}>
	<a href="/" class="brand" aria-label="Nebura Coffee">
		<span class="brand-text">NEBURA<br />COFFEE</span>
		<span class="brand-mark" aria-hidden="true"></span>
	</a>

	<nav aria-label="Main navigation">
		<ul>
			<li><a class={linkClass('about')} href="/about">About</a></li>
			<li><a class={linkClass('technology')} href="/technology">Technology</a></li>
			<li><a class={linkClass('people')} href="/people-culture">People &amp; culture</a></li>
			<li><a class={linkClass('contact')} href="/contact">Contact</a></li>
		</ul>
	</nav>
</header>

<style>
	.topbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 20px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 12px;
		padding: 12px 18px;
		background: rgba(255, 255, 255, 0.95);
		border-radius: 6px;
		text-decoration: none;
	}

	.brand-text {
		font-size: 15px;
		font-weight: 600;
		line-height: 1.1;
		letter-spacing: 0.08em;
		color: #2f2f2f;
	}

	.brand-mark {
		width: 24px;
		height: 24px;
		border-radius: 50%;
		background:
			radial-gradient(circle at 62% 38%, rgba(255, 255, 255, 0.75), rgba(0, 0, 0, 0) 50%),
			radial-gradient(circle at 35% 62%, #3c3c3c, #101010 70%);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.18);
	}

	nav ul {
		list-style: none;
		display: flex;
		gap: 36px;
		margin: 0;
		padding: 0;
	}

	nav a {
		text-decoration: none;
		font-size: 24px;
		font-family: 'Times New Roman', Georgia, serif;
		transition: opacity 0.2s ease;
	}

	.light nav a {
		color: rgba(255, 255, 255, 0.88);
	}

	.dark nav a {
		color: rgba(17, 17, 17, 0.86);
	}

	nav a:hover,
	nav a.active {
		opacity: 1;
		text-decoration: underline;
		text-underline-offset: 5px;
	}

	@media (max-width: 980px) {
		.topbar {
			align-items: flex-start;
			flex-direction: column;
		}

		nav ul {
			gap: 16px;
			flex-wrap: wrap;
		}

		nav a {
			font-size: 20px;
		}
	}
</style>
