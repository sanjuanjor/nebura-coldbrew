---
import SiteHeader from './SiteHeader.astro';
---

<div class="hero-page">
	<SiteHeader current="home" theme="light" />

	<main class="hero-content">
		<h1>
			Cold brew.<br />
			Reinvented with ultrasound.
		</h1>
		<p>Extracted in minutes, not hours.</p>
		<div class="actions">
			<a class="btn btn-primary" href="/technology">Discover the technology</a>
			<a class="btn btn-secondary" href="/about">Get to know Nebura</a>
		</div>
	</main>
</div>

<style>
	:global(body) {
		font-family: Inter, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
		color: #fff;
	}

	.hero-page {
		position: relative;
		min-height: 100vh;
		padding: 28px 48px;
		background-image:
			radial-gradient(circle at center, rgba(10, 8, 6, 0.22), rgba(8, 6, 4, 0.86) 74%),
			url('/hero-coldbrew.png');
		background-size: cover;
		background-position: center;
		overflow: hidden;
	}

	.hero-content {
		max-width: 1180px;
		margin: 20vh auto 0;
	}

	h1 {
		margin: 0;
		max-width: 900px;
		font-family: 'Times New Roman', Georgia, serif;
		font-size: clamp(40px, 7vw, 96px);
		line-height: 1.05;
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	p {
		margin: 28px 0 40px;
		font-size: clamp(20px, 2vw, 36px);
		color: rgba(255, 255, 255, 0.82);
	}

	.actions {
		display: flex;
		gap: 18px;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 14px 28px;
		border-radius: 999px;
		font-size: 15px;
		font-weight: 500;
		text-decoration: none;
		transition: transform 0.2s ease, background-color 0.2s ease;
	}

	.btn:hover {
		transform: translateY(-1px);
	}

	.btn-primary {
		background: #ffffff;
		color: #1a1a1a;
	}

	.btn-secondary {
		background: rgba(0, 0, 0, 0.2);
		color: #fff;
		border: 1px solid rgba(255, 255, 255, 0.65);
	}

	@media (max-width: 980px) {
		.hero-page {
			padding: 22px 20px;
		}

		.hero-content {
			margin-top: 16vh;
		}

		p {
			margin-top: 20px;
		}
	}
</style>
