---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout
	title="People & Culture | Nebura Coffee"
	description="Equipo, cultura y forma de trabajar en Nebura Coffee."
>
	<div class="page">
		<div class="shell">
			<SiteHeader current="people" theme="dark" />

			<main>
				<h1>People &amp; Culture</h1>
				<p>
					Nebura nace en España con mentalidad de laboratorio y ritmo de startup: probar rápido,
					medir y mejorar.
				</p>

				<section class="card-grid">
					<article class="card">
						<h2>Equipo en construcción</h2>
						<p>
							Estamos en una fase inicial, formando un equipo multidisciplinar entre producto,
							tecnología y operaciones de café.
						</p>
					</article>
					<article class="card">
						<h2>Aprendizaje continuo</h2>
						<p>
							Cada iteración técnica se convierte en mejora de proceso, con foco en calidad de taza y
							eficiencia.
						</p>
					</article>
					<article class="card">
						<h2>Ambición global</h2>
						<p>
							Aunque empezamos en España, el objetivo es crear una tecnología de extracción con
							aplicación internacional.
						</p>
					</article>
				</section>
			</main>
		</div>
	</div>
</Layout>

<style>
	.page {
		min-height: 100vh;
		background: #f7f3ef;
		color: #151515;
	}

	.shell {
		max-width: 1180px;
		margin: 0 auto;
		padding: 28px 20px 60px;
	}

	h1 {
		margin: 70px 0 18px;
		font-family: 'Times New Roman', Georgia, serif;
		font-size: clamp(40px, 7vw, 80px);
		line-height: 1.06;
	}

	main > p {
		max-width: 820px;
		font-size: clamp(20px, 2vw, 28px);
		line-height: 1.35;
		color: #2f2f2f;
	}

	.card-grid {
		display: grid;
		gap: 16px;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		margin-top: 26px;
	}

	.card {
		background: #fff;
		padding: 24px;
		border-radius: 18px;
		border: 1px solid rgba(0, 0, 0, 0.08);
	}

	h2 {
		margin: 0 0 10px;
		font-family: 'Times New Roman', Georgia, serif;
		font-size: 30px;
	}

	.card p {
		margin: 0;
		font-size: 17px;
		line-height: 1.6;
		color: #333;
	}
</style>
