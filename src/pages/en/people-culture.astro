---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { siteContent } from '../../content/site-content';

const locale = 'en';
const copy = siteContent[locale];
const page = copy.people;
---

<Layout title={page.metaTitle} description={page.metaDescription} lang={locale}>
	<div class="page">
		<div class="overlay"></div>
		<div class="shell">
			<SiteHeader current="people" theme="light" locale={locale} />

			<main>
				<h1>{page.heading}</h1>
				<p>{page.intro}</p>

				<section class="card-grid">
					{
						page.cards.map((card) => (
							<article class="card">
								<h2>{card.title}</h2>
								<p>{card.text}</p>
							</article>
						))
					}
				</section>
			</main>
		</div>
	</div>
</Layout>

<style>
	.page {
		position: relative;
		min-height: 100vh;
		background-image: var(--nebura-shared-bg);
		background-size: cover;
		background-position: center;
		color: #fff;
	}

	.overlay {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at 68% 36%, rgba(170, 88, 28, 0.22), transparent 38%),
			linear-gradient(180deg, rgba(6, 5, 5, 0.72) 0%, rgba(5, 4, 4, 0.82) 100%);
		pointer-events: none;
	}

	.shell {
		position: relative;
		max-width: 1180px;
		margin: 0 auto;
		padding: 28px 20px 60px;
	}

	h1 {
		margin: 70px 0 18px;
		font-family: 'Times New Roman', Georgia, serif;
		font-size: clamp(40px, 7vw, 80px);
		line-height: 1.06;
	}

	main > p {
		max-width: 820px;
		font-size: clamp(20px, 2vw, 28px);
		line-height: 1.35;
		color: rgba(255, 255, 255, 0.8);
	}

	.card-grid {
		display: grid;
		gap: 16px;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		margin-top: 26px;
	}

	.card {
		background: rgba(26, 25, 25, 0.62);
		padding: 24px;
		border-radius: 18px;
		border: 1px solid rgba(255, 255, 255, 0.16);
		backdrop-filter: blur(5px);
	}

	h2 {
		margin: 0 0 10px;
		font-family: 'Times New Roman', Georgia, serif;
		font-size: 30px;
	}

	.card p {
		margin: 0;
		font-size: 17px;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.78);
	}
</style>
