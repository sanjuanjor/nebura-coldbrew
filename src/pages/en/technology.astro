---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { siteContent } from '../../content/site-content';

const locale = 'en';
const copy = siteContent[locale];
const page = copy.technology;
---

<Layout title={page.metaTitle} description={page.metaDescription} lang={locale}>
	<div class="page">
		<div class="shell">
			<SiteHeader current="technology" theme="dark" locale={locale} />

			<main>
				<h1>{page.heading}</h1>
				<p>{page.intro}</p>

				<section class="card-grid">
					{
						page.cards.map((card) => (
							<article class="card">
								<h2>{card.title}</h2>
								<p>{card.text}</p>
							</article>
						))
					}
				</section>
			</main>
		</div>
	</div>
</Layout>

<style>
	.page {
		min-height: 100vh;
		background: rgba(247, 243, 239, 0.82);
		color: #151515;
	}

	.shell {
		max-width: 1180px;
		margin: 0 auto;
		padding: 28px 20px 60px;
	}

	h1 {
		margin: 70px 0 18px;
		font-family: 'Times New Roman', Georgia, serif;
		font-size: clamp(40px, 7vw, 80px);
		line-height: 1.06;
	}

	main > p {
		max-width: 820px;
		font-size: clamp(20px, 2vw, 28px);
		line-height: 1.35;
		color: #2f2f2f;
	}

	.card-grid {
		display: grid;
		gap: 16px;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		margin-top: 26px;
	}

	.card {
		background: #fff;
		padding: 24px;
		border-radius: 18px;
		border: 1px solid rgba(0, 0, 0, 0.08);
	}

	h2 {
		margin: 0 0 10px;
		font-family: 'Times New Roman', Georgia, serif;
		font-size: 30px;
	}

	.card p {
		margin: 0;
		font-size: 17px;
		line-height: 1.6;
		color: #333;
	}
</style>
