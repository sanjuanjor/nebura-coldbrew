---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { siteContent } from '../../content/site-content';
import { getLocalizedPath, withBase } from '../../lib/i18n';

const locale = 'en';
const copy = siteContent[locale];
const page = copy.technology;
const cardIcons = ['⚡', '◎', '☕'];
---

<Layout title={page.metaTitle} description={page.metaDescription} lang={locale}>
	<div class="page">
		<div class="overlay"></div>
		<div class="shell">
			<SiteHeader current="technology" theme="light" locale={locale} />

			<main>
				<section class="hero">
					<h1>{page.heading}</h1>
					<p class="subheading">{page.subheading}</p>
					<p class="lead">{page.intro}</p>
				</section>

				<section id="how-it-works" class="how-it-works">
					<h2>{page.howItWorksTitle}</h2>
					<div class="card-grid">
					{
						page.cards.map((card, index) => (
							<article class="card">
								<span class="icon" aria-hidden="true">{cardIcons[index] ?? '•'}</span>
								<h3>{card.title}</h3>
								<p class="card-text">{card.text}</p>
							</article>
						))
					}
					</div>
				</section>

				<section class="why">
					<h2>{page.whyTitle}</h2>
					{page.whyParagraphs.map((paragraph) => <p>{paragraph}</p>)}
					<p class="quote">
						<em>
							{page.quote[0]}<br />
							{page.quote[1]}
						</em>
					</p>
					<div class="actions">
						<a class="btn" href="#how-it-works">{page.primaryCta}</a>
						<a class="btn" href={withBase(getLocalizedPath(locale, 'contact'))}>{page.secondaryCta}</a>
					</div>
				</section>
			</main>
		</div>
	</div>
</Layout>

<style>
	.page {
		position: relative;
		min-height: 100vh;
		background-image: var(--nebura-shared-bg);
		background-size: cover;
		background-position: center;
		color: #fff;
	}

	.overlay {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at 68% 36%, rgba(170, 88, 28, 0.26), transparent 38%),
			linear-gradient(180deg, rgba(6, 5, 5, 0.74) 0%, rgba(5, 4, 4, 0.82) 100%);
		pointer-events: none;
	}

	.shell {
		position: relative;
		max-width: 1180px;
		margin: 0 auto;
		padding: 28px 20px 68px;
	}

	main {
		max-width: 860px;
	}

	.hero h1 {
		margin: clamp(72px, 16vh, 138px) 0 10px;
		font-family: 'Times New Roman', Georgia, serif;
		font-size: clamp(44px, 7vw, 74px);
		line-height: 1.08;
		font-weight: 600;
	}

	.subheading {
		margin: 0;
		font-size: clamp(22px, 2.4vw, 34px);
		font-weight: 500;
		color: rgba(255, 255, 255, 0.9);
	}

	.lead {
		margin: 18px 0 0;
		max-width: 720px;
		font-size: clamp(18px, 1.8vw, 28px);
		line-height: 1.35;
		color: rgba(255, 255, 255, 0.8);
	}

	.how-it-works {
		margin-top: clamp(80px, 11vh, 130px);
	}

	h2 {
		margin: 0 0 24px;
		font-family: 'Times New Roman', Georgia, serif;
		font-size: clamp(38px, 5.4vw, 58px);
		line-height: 1.08;
		font-weight: 500;
	}

	.card-grid {
		display: grid;
		gap: 20px;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
	}

	.card {
		padding: 30px 26px;
		border-radius: 16px;
		background: rgba(26, 25, 25, 0.62);
		border: 1px solid rgba(255, 255, 255, 0.16);
		backdrop-filter: blur(5px);
	}

	.icon {
		display: inline-block;
		font-size: 32px;
		line-height: 1;
		color: #f0c49e;
	}

	h3 {
		margin: 16px 0 10px;
		font-size: 32px;
		font-weight: 500;
		line-height: 1.2;
	}

	.card-text {
		margin: 0;
		font-size: 24px;
		line-height: 1.6;
		color: rgba(255, 255, 255, 0.78);
	}

	.why {
		margin-top: clamp(84px, 11vh, 136px);
		padding-bottom: 24px;
	}

	.why > p {
		max-width: 760px;
		font-size: 24px;
		line-height: 1.55;
		color: rgba(255, 255, 255, 0.74);
		margin: 0 0 20px;
	}

	.quote {
		margin-top: 26px;
		font-size: 34px;
		line-height: 1.28;
		color: #f0c49e;
	}

	.actions {
		display: flex;
		gap: 14px;
		flex-wrap: wrap;
		margin-top: 26px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 10px 22px;
		border: 1px solid rgba(255, 255, 255, 0.52);
		border-radius: 999px;
		text-decoration: none;
		color: rgba(255, 255, 255, 0.92);
		font-size: 17px;
		transition: background-color 0.2s ease;
	}

	.btn:hover {
		background: rgba(255, 255, 255, 0.12);
	}

	@media (max-width: 980px) {
		.hero h1 {
			margin-top: 86px;
		}

		h2 {
			font-size: clamp(34px, 8vw, 48px);
		}

		h3,
		.card-text,
		.why > p,
		.quote,
		.btn {
			font-size: clamp(18px, 4.2vw, 24px);
		}

		.quote {
			line-height: 1.35;
		}
	}
</style>
