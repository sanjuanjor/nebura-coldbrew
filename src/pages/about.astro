---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout
	title="About | Nebura Coffee"
	description="Conoce Nebura Coffee, startup de España creada por Julio Quirce para reinventar el cold brew."
>
	<div class="page">
		<div class="shell">
			<SiteHeader current="about" theme="dark" />

			<main>
				<h1>About Nebura</h1>
				<p>
					Nebura Coffee es una empresa de España que está empezando con una misión clara: cambiar la
					forma de preparar cold brew para hacerlo más rápido, consistente y escalable.
				</p>

				<section class="card">
					<h2>Fundador</h2>
					<p>
						El creador de Nebura es <strong>Julio Quirce</strong>, quien impulsa el proyecto combinando
						innovación tecnológica y enfoque en calidad de producto.
					</p>
				</section>

				<section class="card">
					<h2>Visión</h2>
					<p>
						Construir una nueva referencia en café de extracción en frío, donde el tiempo de
						preparación pase de horas a minutos sin perder perfil sensorial.
					</p>
				</section>
			</main>
		</div>
	</div>
</Layout>

<style>
	.page {
		min-height: 100vh;
		background: #f7f3ef;
		color: #151515;
	}

	.shell {
		max-width: 1180px;
		margin: 0 auto;
		padding: 28px 20px 60px;
	}

	h1 {
		margin: 70px 0 18px;
		font-family: 'Times New Roman', Georgia, serif;
		font-size: clamp(40px, 7vw, 80px);
		line-height: 1.06;
	}

	main > p {
		max-width: 820px;
		font-size: clamp(20px, 2vw, 28px);
		line-height: 1.35;
		color: #2f2f2f;
	}

	.card {
		margin-top: 24px;
		max-width: 880px;
		background: #fff;
		padding: 28px;
		border-radius: 18px;
		border: 1px solid rgba(0, 0, 0, 0.08);
	}

	h2 {
		margin: 0 0 10px;
		font-family: 'Times New Roman', Georgia, serif;
		font-size: 34px;
	}

	.card p {
		margin: 0;
		font-size: 18px;
		line-height: 1.6;
		color: #333;
	}
</style>
