---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout
	title="Contact | Nebura Coffee"
	description="Contacta con Nebura Coffee para colaboraciones, prensa o pruebas de producto."
>
	<div class="page">
		<div class="shell">
			<SiteHeader current="contact" theme="dark" />

			<main>
				<h1>Contact</h1>
				<p>
					Si quieres hablar con Nebura sobre producto, colaboración o distribución, estaremos
					encantados de escucharte.
				</p>

				<section class="card">
					<h2>Datos de contacto</h2>
					<p><strong>Empresa:</strong> Nebura Coffee (España)</p>
					<p><strong>Founder:</strong> Julio Quirce</p>
					<p><strong>Email:</strong> hola@nebura.coffee</p>
					<p>
						<strong>Nota:</strong> Puedes cambiar este email por el definitivo cuando tengáis dominio
						activo.
					</p>
				</section>
			</main>
		</div>
	</div>
</Layout>

<style>
	.page {
		min-height: 100vh;
		background: #f7f3ef;
		color: #151515;
	}

	.shell {
		max-width: 1180px;
		margin: 0 auto;
		padding: 28px 20px 60px;
	}

	h1 {
		margin: 70px 0 18px;
		font-family: 'Times New Roman', Georgia, serif;
		font-size: clamp(40px, 7vw, 80px);
		line-height: 1.06;
	}

	main > p {
		max-width: 820px;
		font-size: clamp(20px, 2vw, 28px);
		line-height: 1.35;
		color: #2f2f2f;
	}

	.card {
		margin-top: 24px;
		max-width: 880px;
		background: #fff;
		padding: 28px;
		border-radius: 18px;
		border: 1px solid rgba(0, 0, 0, 0.08);
	}

	h2 {
		margin: 0 0 14px;
		font-family: 'Times New Roman', Georgia, serif;
		font-size: 34px;
	}

	.card p {
		margin: 10px 0;
		font-size: 18px;
		line-height: 1.5;
		color: #333;
	}
</style>
